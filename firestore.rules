rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // First sign-in: create doc with zero balance
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.balance == 0
        && request.resource.data.tier == null;

      // Client updates: cannot change tier or payment fields; balance can only decrease (snooze deductions)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.tier == resource.data.tier
        && request.resource.data.balance <= resource.data.balance
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'stripeCustomerId',
          'depositPaymentIntentId', 'depositPaymentIntentAmount',
          'upgradePaymentIntentId', 'upgradePaymentIntentAmount'
        ]);

      match /transactions/{txId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
